{
  "entities": {
    "Registration": {
      "title": "Registration",
      "description": "A meeting registration form entry",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "maxLength": 128
        },
        "eventId": {
          "type": "string",
          "maxLength": 128
        },
        "eventTitle": {
          "type": "string",
          "maxLength": 256
        },
        "eventDate": {
          "type": "string",
          "maxLength": 128
        },
        "eventLocation": {
          "type": "string",
          "maxLength": 256
        },
        "userName": {
          "type": "string",
          "maxLength": 256
        },
        "userEmail": {
          "type": "string",
          "maxLength": 256
        },
        "userPhone": {
          "type": "string",
          "maxLength": 128
        },
        "userBranch": {
          "type": "string",
          "maxLength": 256
        },
        "ticketCode": {
          "type": "string",
          "maxLength": 128
        },
        "registrationDate": {
          "type": "string",
          "maxLength": 128
        },
        "mode": {
          "type": "string",
          "enum": ["physical", "virtual"]
        }
      },
      "required": ["id", "eventId", "eventTitle", "userName", "userEmail", "userPhone", "ticketCode"]
    },
    "Teaching": {
      "title": "Teaching",
      "description": "An audio sermon or theological teaching track",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "maxLength": 128
        },
        "title": {
          "type": "string",
          "maxLength": 256
        },
        "preacher": {
          "type": "string",
          "maxLength": 256
        },
        "series": {
          "type": "string",
          "maxLength": 256
        },
        "coverUrl": {
          "type": "string",
          "maxLength": 512
        },
        "audioUrl": {
          "type": "string",
          "maxLength": 512
        },
        "duration": {
          "type": "string",
          "maxLength": 64
        },
        "size": {
          "type": "string",
          "maxLength": 64
        },
        "description": {
          "type": "string",
          "maxLength": 1024
        }
      },
      "required": ["id", "title", "preacher", "series", "coverUrl", "audioUrl"]
    }
  },
  "firestore": {
    "/registrations/{registrationId}": {
      "schema": "Registration",
      "description": "Collection of meeting registrations collected from registration forms"
    },
    "/teachings/{teachingId}": {
      "schema": "Teaching",
      "description": "Collection of sermon audios published by church administrators"
    }
  }
}
